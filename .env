# Frontend environment variables (Vite)
# This file is NOT committed to git.

# Leave empty in development — the Vite proxy (vite.config.js) routes /api -> http://localhost:8000
# Set this to your deployed backend URL in production, e.g. https://api.yourdomain.com
VITE_API_BASE_URL=
# Your Telegram bot username (without @) — shown on the registration success page
VITE_TELEGRAM_BOT_USERNAME=LoopedAIBot
